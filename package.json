{
  "name": "264-pro-video-editor",
  "version": "1.0.81",
  "private": true,
  "description": "Professional AI-powered modular video editor.",
  "author": "Mason Brown <mkbrown261@gmail.com>",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:init && concurrently -k --names \"RENDERER,MAIN,PRELOAD,ELECTRON\" --prefix-colors \"cyan,yellow,magenta,green\" \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:electron\"",
    "dev:init": "tsc -p tsconfig.node.json && tsc -p tsconfig.preload.json",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.node.json --watch --preserveWatchOutput",
    "dev:preload": "tsc -p tsconfig.preload.json --watch --preserveWatchOutput",
    "dev:electron": "cross-env VITE_DEV_SERVER_URL=http://localhost:5173 node scripts/dev-electron.mjs",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.node.json && tsc -p tsconfig.preload.json",
    "preview": "vite preview",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "dist:mac": "npm run build && electron-builder --mac --universal",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:all": "npm run build && electron-builder --mac --win"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.1.2",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.2.1",
    "electron-builder": "^26.8.2",
    "jsdom": "^29.0.1",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^4.1.2",
    "wait-on": "^8.0.3"
  }
}
